<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Painel do Mestre</title>
  <link rel="stylesheet" href="../assets/css/admin.css" />
</head>
<body>
  <div class="page-shell">
    <div class="card list-card">
      <div class="authbar-actions">
        <button id="goHomeBtn" type="button">Início</button>
        <button id="goMySheetBtn" type="button">Minha ficha</button>
        <button id="logoutBtn" type="button">Sair</button>
      </div>

      <h1 class="hero-title">Painel do Mestre</h1>
      <div class="notice" id="adminStatus">Carregando...</div>

      <div class="page-actions">
        <button id="refreshBtn" type="button">Atualizar</button>
        <button id="createMySheetBtn" type="button">Criar minha ficha</button>
        <button id="createSelectedUserSheetBtn" type="button" disabled>Criar ficha para usuário selecionado</button>
      </div>

      <div class="admin-grid">
        <section class="admin-panel">
          <h2>Usuários</h2>
          <input id="userSearchInput" type="text" placeholder="Buscar usuário por nome ou e-mail" />
          <div id="usersList" class="sheet-list"></div>
        </section>

        <section class="admin-panel">
          <h2>Fichas</h2>
          <div class="notice" id="selectedUserBox">Nenhum usuário selecionado.</div>
          <div id="sheetsList" class="sheet-list"></div>
        </section>
      </div>
    </div>
  </div>

  <script type="module" src="../assets/js/admin.js"></script>
</body>
</html>
